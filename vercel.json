{
  "buildCommand": "corepack pnpm build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "corepack pnpm install",
  "packageManager": "pnpm@10.30.0",
  "env": {
    "PNPM_IGNORE_SCRIPTS": "false"
  },
  "functions": {
    "app/api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  }
}
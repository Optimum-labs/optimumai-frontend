generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String                  @id @default(cuid())
  supabaseId        String?                 @unique // Link to Supabase auth user
  name              String
  email             String                  @unique
  emailVerified     Boolean                 @default(false)
  dateOfBirth       DateTime?
  verificationToken String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  enrollments       Enrollment[]
  activities        Activity[]
  userLogs          UserLog[]
  challengeRegs     ChallengeRegistration[]
  researchApps      ResearchApplication[]
  eventRegs         EventRegistration[]
}

model Course {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  description String
  category    String       // bootcamp | learning
  duration    String
  level       String       // beginner | intermediate | advanced
  tags        String[]
  createdAt   DateTime     @default(now())
  enrollments Enrollment[]
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String?
  courseId    String
  fullName    String?
  email       String?
  status      String   @default("enrolled") // enrolled | in-progress | completed
  progress    Int      @default(0)          // 0-100 percent
  meetingLink String?
  resumeUrl   String?
  jsonData    Json?
  enrolledAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, email])
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // enrollment | completion | login | paper | internship
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserLog {
  id          String   @id @default(cuid())
  userId      String?
  supabaseId  String?
  action      String   // login | logout | signup | password_change | profile_update | course_enroll | etc.
  description String
  ipAddress   String?
  userAgent   String?
  metadata    Json?    // Additional data like course_id, error_messages, etc.
  success     Boolean  @default(true)
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([supabaseId])
  @@index([action])
  @@index([createdAt])
}

model Challenge {
  id            String                  @id @default(cuid())
  title         String
  slug          String                  @unique
  description   String
  level         String                  // beginner | intermediate | advanced
  duration      String
  prizePool     String?
  partnership   String?
  maxTeams      Int                     @default(10)
  teamSize      Int                     @default(5)
  tags          String[]
  startsAt      DateTime
  registrationCloses DateTime?
  status        String                  @default("open") // open | closed | in-progress | completed
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  registrations ChallengeRegistration[]
}

model ChallengeRegistration {
  id            String    @id @default(cuid())
  challengeId   String
  userId        String?
  fullName      String
  email         String
  linkedIn      String?
  motivation    String
  status        String    @default("pending") // pending | approved | rejected
  meetingLink   String?
  resumeUrl     String?
  jsonData      Json?
  createdAt     DateTime  @default(now())
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([challengeId, email])
  @@index([challengeId])
  @@index([email])
}

model ResearchProgram {
  id            String                @id @default(cuid())
  title         String
  slug          String                @unique
  description   String
  organization  String
  difficulty    String                // beginner | intermediate | advanced
  duration      String
  tags          String[]
  objectives    String[]
  prerequisites String[]
  status        String                @default("accepting") // accepting | in-progress | closed
  meetingLink   String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  applications  ResearchApplication[]
}

model ResearchApplication {
  id          String          @id @default(cuid())
  programId   String
  userId      String?
  fullName    String?
  email       String?
  status      String          @default("pending") // pending | approved | active | completed
  meetingLink String?
  jsonData    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  program     ResearchProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([programId, email])
}

model MeetingLink {
  id        String   @id @default(cuid())
  url       String
  type      String   // 'bootcamp', 'program', 'challenge', 'event'
  entityId  String   // the id of the course, program, challenge, event
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id            String            @id @default(cuid())
  title         String
  slug          String            @unique
  description   String
  date          DateTime
  time          String
  location      String
  type          String            // symposium | workshop | panel | bootcamp | summit
  maxAttendees  Int?
  status        String            @default("upcoming") // upcoming | ongoing | completed | cancelled
  meetingLink   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  registrations EventRegistration[]
}

model EventRegistration {
  id         String   @id @default(cuid())
  eventId    String
  userId     String?
  fullName   String
  email      String
  status     String   @default("registered") // registered | attended | cancelled
  createdAt  DateTime @default(now())
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([eventId, email])
  @@index([eventId])
  @@index([email])
}
